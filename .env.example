# ============================================================
# Docker 监控体系环境变量配置模板
# 使用方法：复制本文件为 .env 并修改对应的值
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 通用配置
# ------------------------------------------------------------
# 时区设置（默认 Asia/Shanghai，影响容器内日志时间显示）
TZ=Asia/Shanghai

# ------------------------------------------------------------
# 镜像版本号
# ------------------------------------------------------------
# Prometheus 时序数据库（默认 v3.10.0）
PROMETHEUS_VERSION=v3.10.0
# Alertmanager 告警管理器（默认 v0.31.1）
ALERTMANAGER_VERSION=v0.31.1
# Loki 日志聚合系统（默认 3.6.7）
LOKI_VERSION=3.6.7
# Grafana Alloy 日志采集代理（默认 v1.14.0）
ALLOY_VERSION=v1.14.0
# Grafana 可视化平台（默认 12.4.1）
GRAFANA_VERSION=12.4.1
# MySQL 数据库，监控体系公共存储（默认 8.4.8）
MYSQL_VERSION=8.4.8
# Uptime Kuma 服务可用性监控（默认 2.2.1）
UPTIME_KUMA_VERSION=2.2.1
# Pushgateway 指标推送网关（默认 v1.11.2）
PUSHGATEWAY_VERSION=v1.11.2
# Node Exporter 主机指标采集器（默认 v1.10.2）
NODE_EXPORTER_VERSION=v1.10.2
# cAdvisor 容器指标采集器（默认 0.56.2）
CADVISOR_VERSION=0.56.2
# Blackbox Exporter 黑盒探测器（默认 v0.28.0）
BLACKBOX_EXPORTER_VERSION=v0.28.0
# PrometheusAlert 告警消息转发（默认 v4.9.2）
PROMETHEUSALERT_VERSION=v4.9.2
# MySQL Exporter 数据库指标采集器（默认 v0.18.0，可选组件）
MYSQL_EXPORTER_VERSION=v0.18.0

# ------------------------------------------------------------
# 端口映射（仅对外暴露的服务）
# ------------------------------------------------------------
# Grafana Web 界面端口（默认 3000）
GRAFANA_PORT=3000
# Uptime Kuma Web 界面端口（默认 3001）
UPTIME_KUMA_PORT=3001
# Prometheus Web 界面端口（默认 9090）
PROMETHEUS_PORT=9090
# PrometheusAlert Web 管理界面端口（默认 8080）
PROMETHEUSALERT_PORT=8080

# ------------------------------------------------------------
# MySQL 配置
# ------------------------------------------------------------
# MySQL root 用户密码（请务必修改为强密码）
MYSQL_ROOT_PASSWORD=please_change_me
# Grafana 使用的数据库名称（默认 grafana）
# Uptime Kuma 使用独立的 kuma 库，由 init 脚本自动创建
MYSQL_DATABASE=grafana

# ------------------------------------------------------------
# Grafana 配置
# ------------------------------------------------------------
# Grafana 管理员密码（请务必修改为强密码）
GF_SECURITY_ADMIN_PASSWORD=please_change_me

# ------------------------------------------------------------
# Uptime Kuma 配置
# ------------------------------------------------------------
# Uptime Kuma 登录账号密码（首次访问 Web 界面时创建）
# Prometheus 需要使用此账号抓取 /metrics 指标端点
# 如修改了 Uptime Kuma 的账号密码，请同步修改 config/prometheus/prometheus.yml
# 中 uptime-kuma job 的 basic_auth 配置
# UPTIME_KUMA_USERNAME=admin
# UPTIME_KUMA_PASSWORD=uptime123

# ------------------------------------------------------------
# Prometheus 配置
# ------------------------------------------------------------
# 指标数据保留天数（默认 15 天）
PROMETHEUS_RETENTION_DAYS=15d

# ------------------------------------------------------------
# Loki 配置
# ------------------------------------------------------------
# 日志数据保留天数（默认 30 天，单位：小时）
LOKI_RETENTION_PERIOD=720h
# Alloy 丢弃超过此时间的旧日志，避免 Loki 拒绝过期时间戳
# 应小于 Loki 的 reject_old_samples_max_age（默认 1w=168h），预留 2h 缓冲
LOG_DROP_OLDER_THAN=166h

# ------------------------------------------------------------
# PrometheusAlert 通知渠道配置（PA_ 前缀）
# 根据实际使用的通知渠道，取消注释并填写对应配置
# ------------------------------------------------------------

# --- 钉钉机器人 ---
# 钉钉机器人 Webhook 地址
PA_DINGTALK_URL=
# 钉钉机器人加签密钥（如启用加签验证）
PA_DINGTALK_SECRET=

# --- 企业微信机器人 ---
# 企业微信机器人 Webhook 地址
PA_WEIXIN_URL=

# --- 飞书机器人 ---
# 飞书机器人 Webhook 地址
PA_FEISHU_URL=
# 飞书机器人加签密钥（如启用加签验证）
PA_FEISHU_SECRET=

# --- Telegram ---
# Telegram Bot Token
PA_TG_TOKEN=
# Telegram Chat ID
PA_TG_CHAT_ID=

# ------------------------------------------------------------
# Docker 配置
# ------------------------------------------------------------
# Docker 数据存储根目录（通过 docker info | grep "Docker Root Dir" 查看）
# 默认为 /var/lib/docker，如修改过 Docker 数据目录请对应修改
DOCKER_DATA_ROOT=/var/lib/docker

# ------------------------------------------------------------
# MySQL Exporter 配置（可选组件，使用 profiles 启用）
# ------------------------------------------------------------
# MySQL Exporter 连接字符串，格式：user:password@tcp(host:port)/database
# 默认连接本地 MySQL 实例
MYSQL_EXPORTER_DATA_SOURCE_NAME=root:please_change_me@tcp(mysql:3306)/
